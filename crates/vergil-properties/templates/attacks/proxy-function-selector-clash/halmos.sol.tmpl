pragma solidity ^0.8.0;
import { {{contract_name}} } from "{{contract_path}}";

contract Attacker_{{attack_id_ident}} {
    function attemptAdmin({{contract_name}} t, address newAdmin) external returns (bool) {
        try t.changeAdmin(newAdmin) {
            return true;
        } catch {
            return false;
        }
    }
}

contract Check_{{attack_id_ident}} {
    {{contract_name}} public target;
    Attacker_{{attack_id_ident}} public attacker;

    constructor() {
        target = new {{contract_name}}();
        attacker = new Attacker_{{attack_id_ident}}();
    }

    function check_admin_selector_protected() public {
        address before = target.admin();
        bool succeeded = attacker.attemptAdmin(target, address(0xBEEF));
        if (succeeded) {
            assert(target.admin() == before);
        }
    }
}
