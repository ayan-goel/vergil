pragma solidity ^0.8.0;
import { {{contract_name}} } from "{{contract_path}}";

contract Attacker_{{attack_id_ident}} {
    function attemptDestruct({{contract_name}} t) external returns (bool) {
        try t.destruct() {
            return true;
        } catch {
            return false;
        }
    }
}

contract Check_{{attack_id_ident}} {
    {{contract_name}} public target;
    Attacker_{{attack_id_ident}} public attacker;

    constructor() {
        target = new {{contract_name}}();
        attacker = new Attacker_{{attack_id_ident}}();
    }

    function check_unauthorized_caller_cannot_destruct() public {
        bool destroyedBefore = target.destroyed();
        bool succeeded = attacker.attemptDestruct(target);
        if (succeeded) {
            assert(target.destroyed() == destroyedBefore);
        }
    }
}
